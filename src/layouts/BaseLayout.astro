---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import type { Lang } from "../i18n/translations";

interface Props {
  title: string;
  lang?: Lang;
}

const { title, lang = "ja" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="TrainBit LLC - Blockchain & DX Solutions" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | TrainBit</title>
  </head>
  <body>
    <Header lang={lang} />
    <main class="min-h-screen pt-16">
      <slot />
    </main>
    <Footer lang={lang} />
    <script is:inline>
      // Language initialization
      (function () {
        const languagePaths = {
          ja: "/",
          en: "/en/",
          "zh-cn": "/zh-cn/",
          "zh-tw": "/zh-tw/",
        };

        function normalizeLanguage(language) {
          const value = language.toLowerCase();
          if (value.startsWith("ja")) return "ja";
          if (value.startsWith("en")) return "en";
          if (value === "zh-tw" || value === "zh-hk" || value === "zh-mo" || value.includes("hant")) return "zh-tw";
          if (value.startsWith("zh")) return "zh-cn";
          return "ja";
        }

        document.querySelectorAll("[data-lang]").forEach((link) => {
          link.addEventListener("click", () => {
            localStorage.setItem("preferred-lang", link.getAttribute("data-lang"));
          });
        });

        const requestedLanguage = new URLSearchParams(location.search).get("lang");
        if (requestedLanguage && requestedLanguage in languagePaths) {
          localStorage.setItem("preferred-lang", requestedLanguage);
          history.replaceState(null, "", location.pathname);
        }

        if (location.pathname === "/" || location.pathname === "/index.html") {
          const preferredLanguage = localStorage.getItem("preferred-lang");
          const detectedLanguage = preferredLanguage || normalizeLanguage(navigator.languages?.[0] || navigator.language || "ja");
          const targetPath = languagePaths[detectedLanguage] || "/";
          if (targetPath !== location.pathname) {
            location.replace(targetPath);
          }
        }
      })();

      // Theme initialization
      (function () {
        const theme = localStorage.getItem("theme");
        if (theme === "dark" || (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
  </body>
</html>
