---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t, getLocalizedPath } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const services = [
  {
    num: "01",
    emoji: "🛡️",
    name: t(lang, "services.1.name"),
    en: t(lang, "services.1.en"),
    targetLabel: t(lang, "services.1.target.label"),
    targetBody: t(lang, "services.1.target.body"),
    formatLabel: t(lang, "services.1.format.label"),
    formatBody: t(lang, "services.1.format.body"),
  },
  {
    num: "02",
    emoji: "🔗",
    name: t(lang, "services.2.name"),
    en: t(lang, "services.2.en"),
    targetLabel: t(lang, "services.2.target.label"),
    targetBody: t(lang, "services.2.target.body"),
    formatLabel: t(lang, "services.2.format.label"),
    formatBody: t(lang, "services.2.format.body"),
  },
  {
    num: "03",
    emoji: "📡",
    name: t(lang, "services.3.name"),
    en: t(lang, "services.3.en"),
    targetLabel: t(lang, "services.3.target.label"),
    targetBody: t(lang, "services.3.target.body"),
    formatLabel: t(lang, "services.3.format.label"),
    formatBody: t(lang, "services.3.format.body"),
  },
];
---

<BaseLayout title={t(lang, "services.title")} lang={lang}>
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-12">
        {t(lang, "services.title")}
      </h1>

      <div class="space-y-8">
        {services.map((svc) => (
          <div class="p-8 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
            <div class="flex items-start gap-4 mb-6">
              <span class="text-4xl shrink-0">{svc.emoji}</span>
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-3 mb-1">
                  <h2 class="text-xl font-bold text-gray-900 dark:text-white">{svc.name}</h2>
                  <span class="text-xs font-medium px-3 py-0.5 rounded-full bg-primary-100 dark:bg-primary-900/40 text-primary-600 dark:text-primary-400">
                    {svc.en}
                  </span>
                  <span class="text-xs font-mono text-gray-400 ml-auto">{svc.num}</span>
                </div>
              </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 pl-0 sm:pl-16">
              <div class="p-4 rounded-xl bg-white dark:bg-gray-900/50 border border-gray-100 dark:border-gray-700">
                <p class="text-xs font-semibold text-primary-500 uppercase tracking-wide mb-2">{svc.targetLabel}</p>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{svc.targetBody}</p>
              </div>
              <div class="p-4 rounded-xl bg-white dark:bg-gray-900/50 border border-gray-100 dark:border-gray-700">
                <p class="text-xs font-semibold text-primary-500 uppercase tracking-wide mb-2">{svc.formatLabel}</p>
                <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{svc.formatBody}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <a
          href={getLocalizedPath("/contact", lang)}
          class="inline-flex items-center px-8 py-3 rounded-full bg-primary-500 text-white font-medium hover:bg-primary-600 transition-colors shadow-lg shadow-primary-500/25"
        >
          {t(lang, "hero.cta.consult")}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
