const content: Record<Lang, Content> = { ja, en, "zh-cn": zhCN, "zh-tw": zhTW };
const c = content[lang];
const sectionClass = "py-20 md:py-28";
const cardIcons = ["M5 7h14M5 12h10M5 17h14", "M12 4v16m8-8H4m12-6 4 4m-12 4-4 4", "M8 12h8m-7 4h6M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z", "M4 12a8 8 0 0 1 16 0M12 4v8l5 3"];
---

<BaseLayout title={c.hero.title} lang={lang}>
  <section class="relative overflow-hidden bg-white dark:bg-gray-950">
    <div class="absolute inset-y-0 left-0 w-2 bg-primary-500" aria-hidden="true"></div>
    <div class="absolute inset-x-0 bottom-0 h-px bg-gray-200 dark:bg-gray-800" aria-hidden="true"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-32">
      <div class="max-w-4xl">
        <p class="text-base font-semibold tracking-[0.22em] uppercase text-primary-500 mb-5">TrainBit Membership</p>
        <h1 class="text-4xl md:text-6xl font-bold leading-tight text-gray-950 dark:text-white mb-6">{c.hero.title}</h1>
        <p class="text-xl md:text-2xl text-gray-800 dark:text-gray-100 leading-relaxed mb-8">{c.hero.subtitle}</p>
        <div class="space-y-4 text-lg text-gray-600 dark:text-gray-400 leading-8 max-w-3xl">
          {c.hero.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </div>
  </section>

  <section class={`${sectionClass} bg-slate-50 dark:bg-gray-900`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-950 dark:text-white mb-14">{c.value.title}</h2>
      <div class="grid gap-7 sm:grid-cols-2 lg:grid-cols-4">
        {c.value.cards.map((card, index) => (
          <article class="rounded-xl border border-slate-200 dark:border-gray-800 bg-white dark:bg-gray-950 p-7 shadow-sm">
            <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full border border-primary-200 bg-primary-50 text-primary-600 dark:border-primary-900/60 dark:bg-primary-950/30 dark:text-primary-300">
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={cardIcons[index]} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-950 dark:text-white mb-4">{card.title}</h3>
            <p class="text-base leading-8 text-gray-600 dark:text-gray-400">{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class={`${sectionClass} bg-white dark:bg-gray-950`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-950 dark:text-white mb-14">{c.plans.title}</h2>
      <div class="grid gap-8 lg:grid-cols-2">
        {c.plans.items.map((plan) => (
          <article class:list={[
            "rounded-xl border-l-4 border-y border-r p-8 md:p-10 shadow-sm",
            plan.featured
              ? "border-l-primary-500 border-y-slate-200 border-r-slate-200 bg-slate-50 dark:border-l-primary-500 dark:border-y-gray-800 dark:border-r-gray-800 dark:bg-gray-900"
              : "border-l-slate-300 border-y-slate-200 border-r-slate-200 bg-white dark:border-l-gray-700 dark:border-y-gray-800 dark:border-r-gray-800 dark:bg-gray-900",
          ]}>
            <h3 class="text-2xl md:text-3xl font-bold text-gray-950 dark:text-white mb-4">{plan.title}</h3>
            <p class="text-3xl font-bold text-primary-500 mb-7">{plan.price}</p>
            <div class="space-y-4 text-base leading-8 text-gray-600 dark:text-gray-400 mb-8">
              {plan.body.map((paragraph) => <p>{paragraph}</p>)}
            </div>
            <ul class="space-y-4 mb-9">
              {plan.features.map((feature) => (
                <li class="flex gap-3 text-base text-gray-700 dark:text-gray-300">
                  <span class="mt-1 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-500/15 text-primary-500">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
                    </svg>
                  </span>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            <a href={getLocalizedPath(plan.href, lang)} class="inline-flex rounded-full bg-primary-500 px-7 py-3.5 text-base font-semibold text-white hover:bg-primary-600 transition-colors shadow-lg shadow-primary-500/20">
              {plan.cta}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class={`${sectionClass} bg-slate-50 dark:bg-gray-950`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-slate-200 bg-white p-8 md:p-14 text-gray-950 shadow-sm dark:border-gray-800 dark:bg-gray-900 dark:text-white">
        <h2 class="text-3xl md:text-5xl font-bold leading-tight mb-6">{c.final.title}</h2>
        <p class="text-lg text-gray-600 dark:text-gray-400 leading-8 max-w-3xl mb-9">{c.final.body}</p>
        <a href={getLocalizedPath("/contact", lang)} class="inline-flex rounded-full bg-primary-500 px-7 py-3.5 text-base font-semibold text-white hover:bg-primary-600 transition-colors">
          {c.final.cta}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
