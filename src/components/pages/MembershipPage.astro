    title: "Service Plans",
    items: [
      {
        title: "Basic Membership",
        price: "JPY 100,000 / month",
        body: ["For companies and institutions that want to stay informed on AI, Web3, and cryptography trends."],
        features: ["Regular industry research and member publications", "Trend briefings on AI, Web3, and cryptography", "Limited advisory consultation support"],
        cta: "Apply to Join",
