        featured: true,
      },
      {
        title: "Enterprise Advisory",
        price: "Custom pricing",
        body: ["For companies working on AI, Web3, or related innovation projects.", "Deeper advisory support can be tailored to your needs, including:"],
        features: ["Technology and business consultation", "Project assessment and planning advice", "Security and risk analysis", "Dedicated research support", "Long-term advisory collaboration"],
