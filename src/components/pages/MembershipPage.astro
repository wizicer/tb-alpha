    ],
  },
  value: {
    title: "What We Provide",
    cards: [
      { title: "Industry Research", body: "Regular coverage of key trends and market developments across AI, Web3, and cryptography." },
      { title: "Expert Insight", body: "Support in understanding the business opportunities and risks behind technology shifts." },
      { title: "Advisory Support", body: "Limited advisory support around technology use, business planning, and risk judgment." },
