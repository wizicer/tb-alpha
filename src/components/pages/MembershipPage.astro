const zhTW: Content = {
  hero: {
    title: "會員制顧問服務",
    subtitle: "持續獲得專業支援",
    body: [
      "AI 與 Web3 技術快速發展，企業真正需要的不只是更多資訊，而是更清晰的判斷。",
      "TrainBit 透過持續性的研究、產業洞察與顧問支援，幫助企業理解技術趨勢、評估發展機會，並降低決策風險。",
    ],
  },
  value: {
    title: "我們提供什麼",
    cards: [
      { title: "產業研究", body: "定期整理 AI、Web3 與密碼學領域的重要趨勢與市場動態。" },
      { title: "專業洞察", body: "幫助企業理解技術變化背後的商業機會與潛在風險。" },
      { title: "顧問支援", body: "圍繞技術應用、業務規劃與風險判斷提供有限顧問支援。" },
