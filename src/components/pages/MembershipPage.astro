      },
      {
        title: "企業顧問服務",
        price: "根據需求定制",
        body: ["適合正在推進 AI、Web3 或相關創新專案的企業。", "根據企業需求提供更深入的顧問支援，包括："],
        features: ["技術與業務諮詢", "專案評估與規劃建議", "安全與風險分析", "專項研究支援", "長期顧問合作"],
