const en: Content = {
  cta: "Contact Us",
  contactCta: "Contact TrainBit",
  hero: {
    brand: "TrainBit",
    title: "Trusted Partner for AI and Web3",
    subtitle: "We help companies understand emerging technologies, reduce decision-making risk, and turn innovation into real business value.",
    body: "Based in Tokyo, TrainBit provides consulting services in AI, Web3, security assessment, and cryptography. We combine local execution support with access to global technical resources, delivering advice that is practical, focused, and ready to act on.",
  },
  services: {
    title: "How We Can Help",
    items: [
      { title: "AI Consulting", body: "Assess, plan, and apply AI technologies with a clear path to business use." },
      { title: "Web3 Consulting", body: "Understand Web3 and explore practical opportunities for new products and business models." },
      { title: "Security Assessment", body: "Identify technical risks and receive focused guidance on security and governance." },
      { title: "Cryptography Consulting", body: "Research and application consulting around zero-knowledge proofs (Zero-Knowledge) and other cryptographic technologies." },
      { title: "Business and Market Support", body: "Connect with the right resources, build partnerships, and enter new markets with confidence." },
    ],
  },
  membership: {
    title: "Advisory Membership",
    subtitle: "Ongoing expert support",
    body: [
      "Technology moves faster than most organizations can update their internal knowledge.",
      "TrainBit Advisory Membership gives companies continuous access to technical consultation, industry insight, research content, and expert support, helping teams make better decisions in a fast-changing market.",
    ],
    items: ["Advisory consultation", "Industry trend analysis", "Research reports and member publications", "Expert sessions and networking", "Project execution support"],
  },
  about: {
    title: "About TrainBit",
    body: [
      "TrainBit is headquartered in Tokyo and works closely with global technical experts and research networks.",
      "We believe the best consulting does not add complexity. It brings clarity, reduces risk, and helps projects move forward with discipline.",
    ],
  },
  contact: {
    title: "Contact Us",
    body: "If you are exploring AI, Web3, security assessment, or cryptography, we would be happy to talk.",
  },
};

const zhTW: Content = {
  cta: "聯繫我們",
  contactCta: "聯繫 TrainBit",
  hero: {
    brand: "TrainBit",
    title: "值得信賴的 AI 與 Web3 顧問夥伴",
    subtitle: "協助企業理解新技術、降低決策風險，並將創新轉化為實際價值。",
    body: "TrainBit 總部位於東京，專注於 AI、Web3、安全評估及密碼學領域的諮詢服務。我們結合本地團隊與全球技術資源，為企業提供專業、務實且可執行的支援。",
  },
  services: {
    title: "我們能為您提供什麼",
    items: [
      { title: "AI 諮詢", body: "協助企業評估、規劃與應用人工智慧技術。" },
      { title: "Web3 諮詢", body: "幫助企業理解 Web3，探索新的業務機會與發展方向。" },
      { title: "安全評估", body: "提供風險評估、安全諮詢及相關專業支援。" },
      { title: "密碼學諮詢", body: "圍繞零知識證明（Zero-Knowledge）等密碼學技術提供研究與應用諮詢。" },
      { title: "商務與市場支援", body: "協助企業連接資源、拓展合作與進入新市場。" },
    ],
  },
  membership: {
    title: "會員制顧問服務",
    subtitle: "持續獲得專業支援",
    body: [
      "技術的發展遠快於企業內部知識的更新速度。",
      "TrainBit 透過會員制顧問服務，為企業持續提供技術諮詢、產業洞察、研究內容及專家支援，幫助客戶在快速變化的環境中做出更準確的判斷。",
    ],
    items: ["顧問諮詢支援", "產業趨勢分析", "研究報告與會員刊物", "專家交流活動", "專案推進支援"],
  },
  about: {
    title: "關於 TrainBit",
    body: [
      "TrainBit 總部位於東京，並與全球技術專家及研究網絡保持長期合作。",
      "我們相信，真正有價值的諮詢服務，不是增加複雜性，而是幫助客戶看清方向、降低風險，並推動專案穩步落地。",
    ],
  },
  contact: {
