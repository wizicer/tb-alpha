---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLocalizedPath } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

type Content = {
  cta: string;
  contactCta: string;
  hero: {
    brand: string;
    title: string;
    subtitle: string;
    body: string;
  };
  services: {
    title: string;
    items: { title: string; body: string }[];
  };
  membership: {
    title: string;
    subtitle: string;
    body: string[];
    items: string[];
  };
  about: {
    title: string;
    body: string[];
  };
  contact: {
    title: string;
    body: string;
  };
};

const zhCN: Content = {
  cta: "联系我们",
  contactCta: "联系 TrainBit",
  hero: {
    brand: "TrainBit",
    title: "可信赖的 AI 与 Web3 顾问伙伴",
    subtitle: "帮助企业理解新技术、降低决策风险，并将创新转化为实际价值。",
    body: "TrainBit 总部位于东京，专注于 AI、Web3、安全评估及密码学领域的咨询服务。我们结合本地团队与全球技术资源，为企业提供专业、务实且可执行的支持。",
  },
  services: {
    title: "我们能为您提供什么",
    items: [
      { title: "AI 咨询", body: "协助企业评估、规划与应用人工智能技术。" },
      { title: "Web3 咨询", body: "帮助企业理解 Web3，探索新的业务机会与发展方向。" },
      { title: "安全评估", body: "提供风险评估、安全咨询及相关专业支持。" },
      { title: "密码学咨询", body: "围绕零知识证明（Zero-Knowledge）等密码学技术提供研究与应用咨询。" },
      { title: "商务与市场支持", body: "协助企业连接资源、拓展合作与进入新市场。" },
    ],
  },
  membership: {
    title: "会员制顾问服务",
    subtitle: "持续获得专业支持",
    body: [
      "技术的发展远快于企业内部知识的更新速度。",
      "TrainBit 通过会员制顾问服务，为企业持续提供技术咨询、行业洞察、研究内容及专家支持，帮助客户在快速变化的环境中做出更准确的判断。",
    ],
    items: ["顾问咨询支持", "行业趋势分析", "研究报告与会员刊物", "专家交流活动", "项目推进支持"],
  },
  about: {
    title: "关于 TrainBit",
    body: [
      "TrainBit 总部位于东京，并与全球技术专家及研究网络保持长期合作。",
      "我们相信，真正有价值的咨询服务，不是增加复杂性，而是帮助客户看清方向、降低风险，并推动项目稳步落地。",
    ],
  },
  contact: {
    title: "联系我们",
    body: "欢迎与我们交流 AI、Web3、安全评估及密码学相关课题。",
  },
};

const ja: Content = {
  cta: "お問い合わせ",
  contactCta: "TrainBit に相談する",
  hero: {
    brand: "TrainBit",
    title: "AI と Web3 の信頼できるアドバイザリーパートナー",
