---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t, getLocalizedPath } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";
import { getCollection } from "astro:content";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const allNews = await getCollection("news");
const newsItems = allNews
  .filter((n) => n.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const strengths = [
  {
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
    title: t(lang, "strengths.1.title"),
    body: t(lang, "strengths.1.body"),
  },
  {
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
    title: t(lang, "strengths.2.title"),
    body: t(lang, "strengths.2.body"),
  },
  {
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    title: t(lang, "strengths.3.title"),
    body: t(lang, "strengths.3.body"),
  },
];

const services = [
  {
    num: "01",
    emoji: "🛡️",
    name: t(lang, "services.1.name"),
    en: t(lang, "services.1.en"),
    targetLabel: t(lang, "services.1.target.label"),
    targetBody: t(lang, "services.1.target.body"),
    formatLabel: t(lang, "services.1.format.label"),
    formatBody: t(lang, "services.1.format.body"),
  },
  {
    num: "02",
    emoji: "🔗",
    name: t(lang, "services.2.name"),
    en: t(lang, "services.2.en"),
    targetLabel: t(lang, "services.2.target.label"),
    targetBody: t(lang, "services.2.target.body"),
    formatLabel: t(lang, "services.2.format.label"),
    formatBody: t(lang, "services.2.format.body"),
  },
  {
    num: "03",
    emoji: "📡",
    name: t(lang, "services.3.name"),
    en: t(lang, "services.3.en"),
    targetLabel: t(lang, "services.3.target.label"),
    targetBody: t(lang, "services.3.target.body"),
    formatLabel: t(lang, "services.3.format.label"),
    formatBody: t(lang, "services.3.format.body"),
  },
];

const workflowSteps = [
  { num: "1", title: t(lang, "workflow.1.title"), body: t(lang, "workflow.1.body") },
  { num: "2", title: t(lang, "workflow.2.title"), body: t(lang, "workflow.2.body") },
  { num: "3", title: t(lang, "workflow.3.title"), body: t(lang, "workflow.3.body") },
  { num: "4", title: t(lang, "workflow.4.title"), body: t(lang, "workflow.4.body") },
];

const companyStructure = [
  { label: t(lang, "company.hq.label"), body: t(lang, "company.hq.body") },
  { label: t(lang, "company.rd.label"), body: t(lang, "company.rd.body") },
  { label: t(lang, "company.advisors.label"), body: t(lang, "company.advisors.body") },
];
---

<BaseLayout title={lang === "ja" ? "TrainBit 合同会社" : "TrainBit LLC"} lang={lang}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-gray-950 via-gray-900 to-primary-950 dark:from-gray-950 dark:via-gray-900 dark:to-primary-950">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary-900/30 via-transparent to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-28 md:py-40 relative">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold tracking-widest uppercase text-primary-400 mb-4">
          {t(lang, "hero.eyebrow")}
        </p>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
          {t(lang, "hero.main")}
        </h1>
        <p class="text-base md:text-lg text-gray-300 leading-relaxed mb-10 max-w-2xl">
          {t(lang, "hero.desc")}
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href={getLocalizedPath("/contact", lang)}
            class="inline-flex items-center px-6 py-3 rounded-full bg-primary-500 text-white font-medium hover:bg-primary-400 transition-colors shadow-lg shadow-primary-500/30"
          >
            {t(lang, "hero.cta.consult")}
          </a>
          <a
            href={getLocalizedPath("/services", lang)}
            class="inline-flex items-center px-6 py-3 rounded-full border border-white/20 text-white font-medium hover:bg-white/10 transition-colors"
          >
            {t(lang, "hero.cta.services")}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Strengths Section -->
  <section class="py-20 md:py-28 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-12">
        {t(lang, "strengths.title")}
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        {strengths.map((item) => (
          <div class="flex flex-col gap-4 p-6 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
            <div class="w-12 h-12 rounded-xl bg-primary-100 dark:bg-primary-900/40 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 dark:text-white mb-2">{item.title}</h3>
              <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-20 md:py-28 bg-gray-50 dark:bg-gray-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
          {t(lang, "services.title")}
        </h2>
        <a
          href={getLocalizedPath("/services", lang)}
          class="text-sm font-medium text-primary-500 hover:text-primary-600 transition-colors"
        >
          {t(lang, "common.learnMore")} →
        </a>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {services.map((svc) => (
          <div class="flex flex-col p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
            <div class="flex items-start justify-between mb-4">
              <span class="text-3xl">{svc.emoji}</span>
              <span class="text-xs font-mono text-gray-400">{svc.num}</span>
            </div>
            <h3 class="font-bold text-gray-900 dark:text-white mb-1">{svc.name}</h3>
            <p class="text-xs text-primary-500 font-medium mb-4">{svc.en}</p>
            <div class="space-y-3 flex-1 text-sm">
              <div>
                <span class="font-semibold text-gray-700 dark:text-gray-300">{svc.targetLabel}: </span>
                <span class="text-gray-600 dark:text-gray-400">{svc.targetBody}</span>
              </div>
              <div>
                <span class="font-semibold text-gray-700 dark:text-gray-300">{svc.formatLabel}: </span>
                <span class="text-gray-600 dark:text-gray-400">{svc.formatBody}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Workflow Section -->
  <section class="py-20 md:py-28 bg-white dark:bg-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-12">
        {t(lang, "workflow.title")}
      </h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {workflowSteps.map((step, i) => (
          <div class="relative flex flex-col gap-3 p-6 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
            <div class="w-10 h-10 rounded-full bg-primary-500 text-white font-bold flex items-center justify-center text-sm shrink-0">
              {step.num}
            </div>
            <h3 class="font-bold text-gray-900 dark:text-white">{step.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{step.body}</p>
            {i < workflowSteps.length - 1 && (
              <div class="hidden lg:block absolute top-10 -translate-y-1/2 -right-7 w-8 text-center text-gray-300 dark:text-gray-600 text-lg font-bold leading-none">→</div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Company Profile Mini Section -->
  <section class="py-20 md:py-28 bg-gray-50 dark:bg-gray-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
          {t(lang, "company.title")}
        </h2>
        <a
          href={getLocalizedPath("/about", lang)}
          class="text-sm font-medium text-primary-500 hover:text-primary-600 transition-colors"
        >
          {t(lang, "common.learnMore")} →
        </a>
      </div>
      <div class="rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700">
          <p class="text-sm font-semibold text-gray-700 dark:text-gray-300">{t(lang, "company.structure.label")}</p>
        </div>
        <div class="divide-y divide-gray-100 dark:divide-gray-700">
          {companyStructure.map((item) => (
            <div class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-4 px-6 py-4">
              <dt class="text-xs font-semibold text-primary-500 sm:w-48 shrink-0">{item.label}</dt>
              <dd class="text-sm text-gray-600 dark:text-gray-400">{item.body}</dd>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Latest News Section -->
  {newsItems.length > 0 && (
    <section class="py-20 md:py-28 bg-white dark:bg-gray-900">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-12">
          <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">
            {t(lang, "news.latestNews")}
          </h2>
          <a
            href={getLocalizedPath("/news", lang)}
            class="text-sm font-medium text-primary-500 hover:text-primary-600 transition-colors"
          >
            {t(lang, "common.learnMore")} →
          </a>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          {newsItems.map((item) => (
            <a
              href={getLocalizedPath(`/news/${item.data.slug}`, lang)}
              class="group rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 hover:border-primary-300 dark:hover:border-primary-700 transition-all"
            >
              <div class="aspect-video overflow-hidden bg-gray-200 dark:bg-gray-700">
                <img
                  src={item.data.image}
                  alt={item.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="p-4">
                <time class="text-xs font-medium text-primary-500">
                  {item.data.date.toISOString().split("T")[0].replace(/-/g, ".")}
                </time>
                <h3 class="font-semibold text-sm text-gray-900 dark:text-white mt-1 line-clamp-2 group-hover:text-primary-500 transition-colors">
                  {item.data.title}
                </h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
