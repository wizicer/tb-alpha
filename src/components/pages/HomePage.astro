const content: Record<Lang, Content> = { ja, en, "zh-cn": zhCN, "zh-tw": zhTW };
const c = content[lang];
const sectionClass = "py-24 md:py-36";
const serviceIcons = [
  "M9 18h6m-7-4h8m-7.5-3.5a3.5 3.5 0 1 1 7 0c0 1.8-.9 2.6-1.9 3.6-.7.7-1.1 1.3-1.1 2.4h-2c0-1.1-.4-1.7-1.1-2.4-1-1-1.9-1.8-1.9-3.6Z",
  "M7 7h4v4H7V7Zm6 6h4v4h-4v-4Zm0-6h4m-10 6h4m1-3h2m-5 6h2m3-9v2m0 8v2M5 5h14v14H5V5Z",
  "M12 3 20 7v5c0 5-3.5 8-8 9-4.5-1-8-4-8-9V7l8-4Zm-3 9 2 2 4-5",
  "M8 16h8M7 12a5 5 0 0 1 10 0M9 8 7 6m8 2 2-2M12 4V2m-4 14 1.5 3h5L16 16",
  "M5 8h14M5 16h14M8 5v14m8-14v14M6 4h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z",
];
---

<BaseLayout title="TrainBit" lang={lang}>
  <section class="relative overflow-hidden bg-gradient-to-br from-gray-950 via-gray-900 to-primary-950">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-primary-900/30 via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-24 md:pt-36 md:pb-36 grid gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="max-w-4xl">
        <p class="text-base font-semibold tracking-[0.22em] uppercase text-primary-400 mb-6">{c.hero.brand}</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight text-white leading-tight mb-7">
          {c.hero.title}
        </h1>
        <p class="text-xl md:text-2xl text-gray-100 leading-relaxed mb-7 max-w-3xl">
          {c.hero.subtitle}
        </p>
        <p class="text-lg text-gray-300 leading-8 max-w-3xl mb-11">
          {c.hero.body}
        </p>
        <a href={getLocalizedPath("/contact", lang)} class="inline-flex rounded-full bg-primary-500 px-7 py-3.5 text-base font-semibold text-white hover:bg-primary-400 transition-colors shadow-lg shadow-primary-500/25">
          {c.cta}
        </a>
      </div>
      <div class="hidden lg:block" aria-hidden="true">
        <div class="relative mx-auto max-w-md">
          <div class="absolute -inset-6 rounded-full bg-primary-500/10 blur-3xl"></div>
          <svg class="relative h-auto w-full drop-shadow-2xl" viewBox="0 0 520 420" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="42" y="36" width="436" height="348" rx="28" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.16)" />
            <path d="M95 112h330M95 190h330M95 268h330" stroke="rgba(255,255,255,0.12)" stroke-width="2" />
            <circle cx="135" cy="112" r="18" fill="#F97316" fill-opacity="0.9" />
            <circle cx="260" cy="190" r="18" fill="#FDBA74" fill-opacity="0.8" />
            <circle cx="385" cy="268" r="18" fill="#F97316" fill-opacity="0.75" />
            <path d="M153 112c45 0 62 78 107 78s80 78 125 78" stroke="url(#hero-line)" stroke-width="4" stroke-linecap="round" />
            <rect x="92" y="310" width="104" height="34" rx="17" fill="rgba(249,115,22,0.16)" stroke="rgba(249,115,22,0.35)" />
            <rect x="214" y="310" width="86" height="34" rx="17" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.16)" />
            <rect x="318" y="310" width="110" height="34" rx="17" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.16)" />
            <path d="M123 151h72m-72 28h118m83-28h72m-72 28h96M123 229h72m-72 28h118" stroke="rgba(255,255,255,0.42)" stroke-width="8" stroke-linecap="round" />
            <defs>
              <linearGradient id="hero-line" x1="153" y1="112" x2="385" y2="268" gradientUnits="userSpaceOnUse">
                <stop stop-color="#F97316" />
                <stop offset="1" stop-color="#FED7AA" />
              </linearGradient>
            </defs>
          </svg>
        </div>
      </div>
    </div>
  </section>

  <section id="services" class={`${sectionClass} bg-primary-50/70 dark:bg-gray-900/70`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-950 dark:text-white leading-tight">{c.services.title}</h2>
      </div>
      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {c.services.items.map((service, index) => (
          <article class="rounded-xl border border-primary-100/80 dark:border-gray-800 bg-white dark:bg-gray-900 p-9 md:p-10 shadow-sm shadow-primary-900/5">
            <div class="mb-8 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary-500 to-primary-300 text-white shadow-lg shadow-primary-500/20">
              <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={serviceIcons[index]} />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-950 dark:text-white mb-5">{service.title}</h3>
            <p class="text-base text-gray-600 dark:text-gray-400 leading-8">{service.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="membership" class={`${sectionClass} bg-gray-950 text-white`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid gap-16 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="text-base font-semibold text-primary-400 mb-4">{c.membership.subtitle}</p>
        <h2 class="text-4xl md:text-5xl font-bold mb-8">{c.membership.title}</h2>
        <div class="space-y-5 text-lg text-gray-300 leading-8">
          {c.membership.body.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <a href={getLocalizedPath("/membership", lang)} class="mt-9 inline-flex rounded-full bg-primary-500 px-7 py-3.5 text-base font-semibold text-white hover:bg-primary-600 transition-colors shadow-lg shadow-primary-500/20">
          {lang === "ja" ? "詳しく見る" : lang === "en" ? "Learn more" : lang === "zh-tw" ? "更多" : "更多"}
        </a>
      </div>
      <div class="rounded-xl border border-white/10 bg-white/[0.06] p-9 md:p-12 shadow-2xl shadow-black/20">
        <ul class="grid gap-5">
          {c.membership.items.map((item) => (
            <li class="flex gap-4 text-base md:text-lg text-gray-200">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary-500/15 text-primary-300">
                <svg class="h-[18px] w-[18px]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
                </svg>
              </span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section id="about" class={`${sectionClass} bg-white dark:bg-gray-950`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid gap-12 lg:grid-cols-[0.85fr_1.15fr]">
      <h2 class="text-4xl md:text-5xl font-bold text-gray-950 dark:text-white leading-tight">{c.about.title}</h2>
      <div class="space-y-6 text-lg text-gray-600 dark:text-gray-400 leading-8">
        {c.about.body.map((paragraph) => <p>{paragraph}</p>)}
        <a href={getLocalizedPath("/about", lang)} class="inline-flex text-base font-semibold text-primary-500 hover:text-primary-600 transition-colors">
          {lang === "ja" ? "詳しく見る" : lang === "en" ? "Learn more" : lang === "zh-tw" ? "更多" : "更多"} →
        </a>
      </div>
    </div>
  </section>

  <section id="contact" class={`${sectionClass} bg-gray-100 dark:bg-gray-950`}>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-gray-800 bg-gradient-to-br from-gray-950 via-gray-900 to-primary-950 p-9 md:p-14 text-white shadow-xl shadow-gray-950/10">
        <h2 class="text-3xl md:text-5xl font-bold mb-5">{c.contact.title}</h2>
        <p class="text-lg text-gray-300 leading-8 max-w-2xl mb-9">{c.contact.body}</p>
        <a href={getLocalizedPath("/contact", lang)} class="inline-flex rounded-full bg-primary-500 px-7 py-3.5 text-base font-semibold text-white hover:bg-primary-600 transition-colors">
          {c.contactCta}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
