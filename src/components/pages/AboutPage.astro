---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const infoItemsBefore = [
  { label: t(lang, "about.name.label"), value: t(lang, "about.name") },
  { label: t(lang, "about.representative.label"), value: t(lang, "about.representative") },
  { label: t(lang, "about.capital.label"), value: t(lang, "about.capital") },
  { label: t(lang, "about.established.label"), value: t(lang, "about.established") },
  { label: t(lang, "about.address.label"), value: t(lang, "about.address") },
];

const emailLabel = t(lang, "about.email.label");

const infoItemsAfter = [
  {
    label: t(lang, "about.hours.label"),
    value: `${t(lang, "about.hours")} / ${t(lang, "about.holidays")}`,
  },
];

const purposes = [
  t(lang, "about.purpose.1"),
  t(lang, "about.purpose.2"),
  t(lang, "about.purpose.3"),
  t(lang, "about.purpose.4"),
  t(lang, "about.purpose.5"),
  t(lang, "about.purpose.6"),
  t(lang, "about.purpose.7"),
];

const intro: Record<Lang, string> = {
  ja: "TrainBit は東京に本社を置き、世界中の技術専門家および研究ネットワークと長期的に連携しています。",
  en: "TrainBit is headquartered in Tokyo and maintains long-term collaboration with global technical experts and research networks.",
  "zh-cn": "TrainBit 总部位于东京，并与全球技术专家及研究网络保持长期合作。",
  "zh-tw": "TrainBit 總部位於東京，並與全球技術專家及研究網絡保持長期合作。",
};
---

<BaseLayout title={t(lang, "about.title")} lang={lang}>
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-12">
        {t(lang, "about.title")}
      </h1>
      <p class="text-lg leading-8 text-gray-600 dark:text-gray-400 mb-12">
        {intro[lang]}
      </p>

      <h2 class="text-xl md:text-2xl font-bold text-primary-500 mb-8 flex items-center gap-3">
        <span class="w-1 h-8 bg-primary-500 rounded-full"></span>
        {t(lang, "about.info.title")}
      </h2>

      <div class="rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 overflow-hidden">
        <dl class="divide-y divide-gray-200 dark:divide-gray-700">
          {infoItemsBefore.map((item) => (
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-1/3 font-medium text-gray-900 dark:text-white text-sm">
                {item.label}
              </dt>
              <dd class="sm:w-2/3 text-gray-600 dark:text-gray-400 text-sm mt-1 sm:mt-0">
                {item.value}
              </dd>
            </div>
          ))}
          <div class="flex flex-col sm:flex-row px-6 py-4">
            <dt class="sm:w-1/3 font-medium text-gray-900 dark:text-white text-sm">
              {emailLabel}
            </dt>
            <dd class="sm:w-2/3 text-gray-600 dark:text-gray-400 text-sm mt-1 sm:mt-0">
              <span
                class="protected-email"
                data-u="hello"
                data-d="trainbit"
                data-t="co.jp"
              >
                <noscript>hello [at] trainbit.co.jp</noscript>
              </span>
            </dd>
          </div>
          {infoItemsAfter.map((item) => (
            <div class="flex flex-col sm:flex-row px-6 py-4">
              <dt class="sm:w-1/3 font-medium text-gray-900 dark:text-white text-sm">
                {item.label}
              </dt>
              <dd class="sm:w-2/3 text-gray-600 dark:text-gray-400 text-sm mt-1 sm:mt-0">
                {item.value}
              </dd>
            </div>
          ))}
          <div class="px-6 py-4">
            <dt class="font-medium text-gray-900 dark:text-white text-sm mb-3">
              {t(lang, "about.purpose.label")}
            </dt>
            <dd>
              <ol class="list-decimal list-inside space-y-1 text-sm text-gray-600 dark:text-gray-400">
                {purposes.map((p) => (
                  <li>{p}</li>
                ))}
              </ol>
            </dd>
          </div>
        </dl>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>(".protected-email").forEach((el) => {
    const u = el.dataset.u ?? "";
    const d = el.dataset.d ?? "";
    const t = el.dataset.t ?? "";
    const email = `${u}@${d}.${t}`;
    const a = document.createElement("a");
    a.href = `mailto:${email}`;
    a.textContent = email;
    a.className = "hover:underline";
    el.innerHTML = "";
    el.appendChild(a);
  });
</script>
