---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t, getLocalizedPath } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";
import { getCollection } from "astro:content";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const allNews = await getCollection("news");
const newsItems = allNews
  .filter((n) => n.data.lang === lang)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title={t(lang, "news.title")} lang={lang}>
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-12">
        {t(lang, "news.title")}
      </h1>

      {newsItems.length === 0 ? (
        <p class="text-gray-500 dark:text-gray-400 text-center py-12">
          {lang === "ja" ? "ニュースはまだありません。" : "No news articles yet."}
        </p>
      ) : (
        <div class="space-y-8">
          {newsItems.map((item) => (
            <a
              href={getLocalizedPath(`/news/${item.data.slug}`, lang)}
              class="group flex flex-col sm:flex-row gap-6 p-6 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 hover:border-primary-300 dark:hover:border-primary-700 transition-all"
            >
              <div class="sm:w-48 shrink-0 aspect-video sm:aspect-[4/3] rounded-lg overflow-hidden bg-gray-200 dark:bg-gray-700">
                <img
                  src={item.data.image}
                  alt={item.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
              <div class="flex-1 min-w-0">
                <time class="text-sm font-medium text-primary-500">
                  {item.data.date.toISOString().split("T")[0].replace(/-/g, ".")}
                </time>
                <h2 class="text-lg font-semibold text-gray-900 dark:text-white mt-1 mb-2 group-hover:text-primary-500 transition-colors">
                  {item.data.title}
                </h2>
                <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-3">
                  {item.data.excerpt}
                </p>
                <span class="inline-block mt-3 text-sm font-medium text-primary-500">
                  {t(lang, "news.readMore")} →
                </span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
