---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t, getLocalizedPath } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";

interface Props {
  lang: Lang;
  entry: CollectionEntry<"news">;
}

const { lang, entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} lang={lang}>
  <article class="py-16 md:py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a
        href={getLocalizedPath("/news", lang)}
        class="inline-flex items-center gap-1 text-sm text-primary-500 hover:text-primary-600 transition-colors mb-8"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        {t(lang, "news.backToList")}
      </a>

      <div class="mb-8">
        <time class="text-sm font-medium text-primary-500">
          {entry.data.date.toISOString().split("T")[0].replace(/-/g, ".")}
        </time>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mt-2">
          {entry.data.title}
        </h1>
      </div>

      <div class="aspect-video rounded-xl overflow-hidden bg-gray-200 dark:bg-gray-700 mb-10">
        <img
          src={entry.data.image}
          alt={entry.data.title}
          class="w-full h-full object-cover"
        />
      </div>

      <div class="prose prose-gray dark:prose-invert max-w-none prose-headings:text-gray-900 dark:prose-headings:text-white prose-a:text-primary-500 hover:prose-a:text-primary-600">
        <Content />
      </div>
    </div>
  </article>
</BaseLayout>
