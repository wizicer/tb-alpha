---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t, getLocalizedPath } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<BaseLayout title={t(lang, "contact.title")} lang={lang}>
  <section class="py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        {t(lang, "contact.title")}
      </h1>
      <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-10">
        {t(lang, "contact.intro")}
      </p>

      <form class="space-y-6" action="#" method="POST">
        <div>
          <label for="company" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.company")}
          </label>
          <input
            type="text"
            id="company"
            name="company"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          />
        </div>

        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.name")}<span class="text-red-500">{t(lang, "contact.name.required")}</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.email")}<span class="text-red-500">{t(lang, "contact.email.required")}</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          />
        </div>

        <div>
          <label for="category" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.category")}
          </label>
          <select
            id="category"
            name="category"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          >
            <option value="">{t(lang, "contact.category")}</option>
            <option value="ai">{t(lang, "contact.category.ai")}</option>
            <option value="web3">{t(lang, "contact.category.web3")}</option>
            <option value="subscription">{t(lang, "contact.category.subscription")}</option>
            <option value="other">{t(lang, "contact.category.other")}</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.message")}<span class="text-red-500">{t(lang, "contact.name.required")}</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all resize-y"
          ></textarea>
        </div>

        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="privacy"
            name="privacy"
            required
            class="mt-1 w-4 h-4 rounded border-gray-300 text-primary-500 focus:ring-primary-500"
          />
          <label for="privacy" class="text-sm text-gray-600 dark:text-gray-400">
            {t(lang, "contact.privacy")}
            <span class="text-red-500">{t(lang, "contact.privacy.required")}</span>
            <br />
            <a href={getLocalizedPath("/privacy", lang)} class="text-primary-500 hover:underline">
              {t(lang, "contact.privacy.link")}
            </a>
          </label>
        </div>

        <button
          type="submit"
          class="w-full py-3 px-6 rounded-lg bg-primary-500 text-white font-medium hover:bg-primary-600 focus:ring-4 focus:ring-primary-500/25 transition-all"
        >
          {t(lang, "contact.submit")}
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
