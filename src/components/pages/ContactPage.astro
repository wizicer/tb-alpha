---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t, getLocalizedPath } from "../../i18n/translations";
import type { Lang } from "../../i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<BaseLayout title={t(lang, "contact.title")} lang={lang}>
  <section class="py-16 md:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
        {t(lang, "contact.title")}
      </h1>
      <p class="text-gray-600 dark:text-gray-400 leading-relaxed mb-10">
        {t(lang, "contact.intro")}
      </p>

      <!-- Status messages -->
      <div id="msg-success" class="hidden mb-6 p-4 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 text-green-800 dark:text-green-300 text-sm">
        {t(lang, "contact.success")}
      </div>
      <div id="msg-error" class="hidden mb-6 p-4 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-700 text-red-800 dark:text-red-300 text-sm">
        {t(lang, "contact.error")}
      </div>

      <form id="contact-form" class="space-y-6">
        <div>
          <label for="company" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.company")}
          </label>
          <input
            type="text"
            id="company"
            name="company"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          />
        </div>

        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.name")}<span class="text-red-500">{t(lang, "contact.name.required")}</span>
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.email")}<span class="text-red-500">{t(lang, "contact.email.required")}</span>
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.phone")}
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          />
        </div>

        <div>
          <label for="category" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.category")}
          </label>
          <select
            id="category"
            name="category"
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all"
          >
            <option value="">{t(lang, "contact.category")}</option>
            <option value="ai">{t(lang, "contact.category.ai")}</option>
            <option value="web3">{t(lang, "contact.category.web3")}</option>
            <option value="cryptography">{t(lang, "contact.category.cryptography")}</option>
            <option value="membership">{t(lang, "contact.category.membership")}</option>
            <option value="other">{t(lang, "contact.category.other")}</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
            {t(lang, "contact.message")}<span class="text-red-500">{t(lang, "contact.name.required")}</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            class="w-full px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all resize-y"
          ></textarea>
        </div>

        <div class="flex items-start gap-3">
          <input
            type="checkbox"
            id="privacy"
            name="privacy"
            required
            class="mt-1 w-4 h-4 rounded border-gray-300 text-primary-500 focus:ring-primary-500"
          />
          <label for="privacy" class="text-sm text-gray-600 dark:text-gray-400">
            {t(lang, "contact.privacy")}
            <span class="text-red-500">{t(lang, "contact.privacy.required")}</span>
            <br />
            <a href={getLocalizedPath("/privacy", lang)} class="text-primary-500 hover:underline">
              {t(lang, "contact.privacy.link")}
            </a>
          </label>
        </div>

        <button
          id="submit-btn"
          type="submit"
          class="w-full py-3 px-6 rounded-lg bg-primary-500 text-white font-medium hover:bg-primary-600 focus:ring-4 focus:ring-primary-500/25 transition-all disabled:opacity-60 disabled:cursor-not-allowed"
        >
          {t(lang, "contact.submit")}
        </button>

        <!-- Draft load inline hint -->
        <div id="draft-banner" class="hidden flex items-center gap-1.5 text-sm text-gray-400 dark:text-gray-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span>{t(lang, "contact.draft.hint")} </span><button
            id="load-draft-btn"
            type="button"
            class="border-b border-dashed border-gray-400 dark:border-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors cursor-pointer bg-transparent p-0"
          >{t(lang, "contact.draft.load")}</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const DRAFT_KEY = "contact_draft";
  const SENT_KEY = "contact_sent";
  const WEBHOOK_URL = "https://trainbit-contact-form.sutu.workers.dev";

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const msgSuccess = document.getElementById("msg-success") as HTMLElement;
  const msgError = document.getElementById("msg-error") as HTMLElement;
  const draftBanner = document.getElementById("draft-banner") as HTMLElement;
  const loadDraftBtn = document.getElementById("load-draft-btn") as HTMLButtonElement;

  const fields = ["company", "name", "email", "phone", "category", "message"] as const;

  function getFormData() {
    const data: Record<string, string> = {};
    fields.forEach((f) => {
      const el = document.getElementById(f) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
      if (el) data[f] = el.value;
    });
    return data;
  }

  function setFormData(data: Record<string, string>) {
    fields.forEach((f) => {
      const el = document.getElementById(f) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;
      if (el && data[f] !== undefined) el.value = data[f];
    });
  }

  function saveDraft() {
    const data = getFormData();
    const hasContent = Object.values(data).some((v) => v.trim() !== "");
    if (hasContent) {
      localStorage.setItem(DRAFT_KEY, JSON.stringify(data));
    }
  }

  function checkSentDraft() {
    const sent = localStorage.getItem(SENT_KEY);
    if (sent) {
      draftBanner.classList.remove("hidden");
    }
  }

  fields.forEach((f) => {
    const el = document.getElementById(f);
    if (el) el.addEventListener("input", saveDraft);
  });

  loadDraftBtn.addEventListener("click", () => {
    const raw = localStorage.getItem(SENT_KEY);
    if (!raw) return;
    try {
      setFormData(JSON.parse(raw));
    } catch {}
  });

  checkSentDraft();

  const draft = localStorage.getItem(DRAFT_KEY);
  if (draft) {
    try {
      setFormData(JSON.parse(draft));
    } catch {}
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    msgSuccess.classList.add("hidden");
    msgError.classList.add("hidden");
    submitBtn.disabled = true;

    const data = getFormData();

    try {
      const res = await fetch(WEBHOOK_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      const json = await res.json();
      if (res.ok && json.success === true) {
        localStorage.setItem(SENT_KEY, JSON.stringify(data));
        localStorage.removeItem(DRAFT_KEY);
        form.reset();
        draftBanner.classList.remove("hidden");
        msgSuccess.classList.remove("hidden");
      } else {
        throw new Error(json.errmsg ?? "error");
      }
    } catch {
      msgError.classList.remove("hidden");
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
