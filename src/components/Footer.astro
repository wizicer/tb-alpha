---
import type { Lang } from "../i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        © 2026 TrainBit. All rights reserved.
      </p>
      <a
        href="https://x.com/trainbit_jp"
        target="_blank"
        rel="noopener noreferrer"
        class="text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors"
        aria-label="TrainBit on X"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.514l-5.106-6.694-5.829 6.694h-3.308l7.73-8.835L.424 2.25h6.679l4.882 6.268 5.259-6.268zM17.002 20.331h1.834L6.822 4.169H4.881l12.121 16.162z" />
        </svg>
      </a>
    </div>
  </div>
</footer>
