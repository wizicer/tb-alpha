---
import { t, getLocalizedPath } from "../i18n/translations";
import type { Lang } from "../i18n/translations";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="bg-gray-50 dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-gray-500 dark:text-gray-400">
        {t(lang, "footer.copyright")}
      </p>
      <a
        href={getLocalizedPath("/privacy", lang)}
        class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-500 transition-colors"
      >
        {t(lang, "footer.privacy")}
      </a>
    </div>
  </div>
</footer>
