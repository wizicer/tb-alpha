---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n/translations";

const lang = "en";
---

<BaseLayout title={t(lang, "services.title")} lang={lang}>
  <section class="py-16 md:py-24">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-12">
        {t(lang, "services.title")}
      </h1>

      <h2 class="text-xl md:text-2xl font-bold text-primary-500 mb-8 flex items-center gap-3">
        <span class="w-1 h-8 bg-primary-500 rounded-full"></span>
        {t(lang, "services.products.title")}
      </h2>

      <div class="grid gap-8 md:grid-cols-2 mb-16">
        <!-- DeML OS -->
        <div class="p-6 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 flex flex-col">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-gray-900 dark:text-white">
              {t(lang, "services.deml.name")}
            </h3>
            <span class="text-xs font-medium px-3 py-1 rounded-full bg-accent-500 text-white">
              {t(lang, "services.deml.stage")}
            </span>
          </div>
          <p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed">
            {t(lang, "services.deml.summary")}
          </p>
          <div class="space-y-3 text-sm mb-6 flex-1">
            <div>
              <h4 class="font-semibold text-accent-500 mb-1">{t(lang, "services.deml.scope.title")}</h4>
              <p class="text-gray-600 dark:text-gray-400">{t(lang, "services.deml.scope.body")}</p>
            </div>
            <div>
              <h4 class="font-semibold text-gray-500 mb-1">{t(lang, "services.deml.outscope.title")}</h4>
              <p class="text-gray-600 dark:text-gray-400">{t(lang, "services.deml.outscope.body")}</p>
            </div>
            <div>
              <h4 class="font-semibold text-primary-500 mb-1">{t(lang, "services.deml.eval.title")}</h4>
              <p class="text-gray-600 dark:text-gray-400">{t(lang, "services.deml.eval.body")}</p>
            </div>
          </div>
          <a
            href="https://deml.space/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm font-medium text-primary-500 hover:text-primary-600 transition-colors"
          >
            {t(lang, "common.visitSite")}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- zkDaily -->
        <div class="p-6 rounded-2xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700 flex flex-col">
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-4">
            {t(lang, "services.zkdaily.name")}
          </h3>
          <p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed">
            {t(lang, "services.zkdaily.summary")}
          </p>
          <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed mb-6 flex-1">
            {t(lang, "services.zkdaily.value")}
          </p>
          <a
            href="https://hints.plonk.pro/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 text-sm font-medium text-primary-500 hover:text-primary-600 transition-colors"
          >
            {t(lang, "common.visitSite")}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Solutions & Consulting -->
      <h2 class="text-xl md:text-2xl font-bold text-primary-500 mb-8 flex items-center gap-3">
        <span class="w-1 h-8 bg-primary-500 rounded-full"></span>
        {t(lang, "services.solutions.title")}
      </h2>

      <div class="grid gap-6 md:grid-cols-3">
        {[
          { title: t(lang, "services.blockchain.title"), body: t(lang, "services.blockchain.body"), icon: "M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" },
          { title: t(lang, "services.dx.title"), body: t(lang, "services.dx.body"), icon: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" },
          { title: t(lang, "services.education.title"), body: t(lang, "services.education.body"), icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
        ].map((item) => (
          <div class="p-6 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
            <div class="w-10 h-10 rounded-lg bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-gray-900 dark:text-white mb-2">{item.title}</h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
