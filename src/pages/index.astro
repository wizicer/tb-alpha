---
import BaseLayout from "../layouts/BaseLayout.astro";
import { t } from "../i18n/translations";

const lang = "ja";
---

<BaseLayout title="TrainBit 合同会社" lang={lang}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-50 via-white to-accent-50 dark:from-gray-900 dark:via-gray-800 dark:to-gray-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 md:py-36">
      <div class="max-w-3xl">
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-4">
          {t(lang, "hero.sub")}
        </p>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white leading-tight mb-8">
          {t(lang, "hero.main")}
        </h1>
        <div class="flex flex-wrap gap-4">
          <a
            href="/services"
            class="inline-flex items-center px-6 py-3 rounded-full bg-primary-500 text-white font-medium hover:bg-primary-600 transition-colors shadow-lg shadow-primary-500/25"
          >
            {t(lang, "hero.cta.services")}
          </a>
          <a
            href="/contact"
            class="inline-flex items-center px-6 py-3 rounded-full border-2 border-primary-500 text-primary-500 font-medium hover:bg-primary-50 dark:hover:bg-primary-900/20 transition-colors"
          >
            {t(lang, "hero.cta.contact")}
          </a>
        </div>
      </div>
    </div>
    <!-- Decorative element -->
    <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary-100/30 dark:from-primary-900/10 to-transparent pointer-events-none"></div>
  </section>

  <!-- News Section -->
  <section class="py-16 md:py-24 bg-white dark:bg-gray-800/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white mb-8">
        {t(lang, "news.title")}
      </h2>
      <div class="space-y-6">
        <article class="flex flex-col sm:flex-row gap-4 p-6 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
          <time class="text-sm font-medium text-primary-500 whitespace-nowrap pt-0.5">
            {t(lang, "news.date.20260309")}
          </time>
          <div>
            <h3 class="font-semibold text-gray-900 dark:text-white mb-1">
              {t(lang, "news.item.20260309.title")}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">
              {t(lang, "news.item.20260309.body")}
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
