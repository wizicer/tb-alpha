---
import BaseLayout from "../layouts/BaseLayout.astro";
import { t } from "../i18n/translations";

const lang = "ja";
---

<BaseLayout title={t(lang, "news.title")} lang={lang}>
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-12">
        {t(lang, "news.title")}
      </h1>
      <div class="space-y-6">
        <article class="p-6 rounded-xl bg-gray-50 dark:bg-gray-800 border border-gray-100 dark:border-gray-700">
          <div class="flex flex-col sm:flex-row gap-4">
            <time class="text-sm font-medium text-primary-500 whitespace-nowrap pt-0.5">
              {t(lang, "news.date.20260309")}
            </time>
            <div>
              <h2 class="font-semibold text-gray-900 dark:text-white mb-2">
                {t(lang, "news.item.20260309.title")}
              </h2>
              <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
                {t(lang, "news.item.20260309.body")}
              </p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
